<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AppCenar</title>
    <link rel="stylesheet" href="/bootstrap-5.3.8-dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body class="bg-light">
    <nav class="navbar navbar-expand-lg bg-dark navbar-dark shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-semibold" href="/">
                AppCenar
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    {{#if user}}
                    {{#if (eq user.role "cliente")}}
                    <li class="nav-item"><a class="nav-link" href="/cliente">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/cliente/orders">Mis pedidos</a></li>
                    <li class="nav-item"><a class="nav-link" href="/cliente/addresses">Mis direcciones</a></li>
                    <li class="nav-item"><a class="nav-link" href="/cliente/favorites">Mis favoritos</a></li>
                    <li class="nav-item"><a class="nav-link" href="/cliente/cart">Carrito ({{cartCount}})</a></li>
                    {{/if}}
                    {{#if (eq user.role "comercio")}}
                    <li class="nav-item"><a class="nav-link" href="/comercio">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/comercio/categories">Categorias</a></li>
                    <li class="nav-item"><a class="nav-link" href="/comercio/products">Productos</a></li>
                    <li class="nav-item"><a class="nav-link" href="/comercio/orders">Pedidos</a></li>
                    {{/if}}
                    {{#if (eq user.role "delivery")}}
                    <li class="nav-item"><a class="nav-link" href="/delivery">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/delivery/orders">Disponibles</a></li>
                    <li class="nav-item"><a class="nav-link" href="/delivery/myOrders">Mis pedidos</a></li>
                    {{/if}}
                    {{#if (eq user.role "admin")}}
                    <li class="nav-item"><a class="nav-link" href="/admin">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/admin/users/cliente">Clientes</a></li>
                    <li class="nav-item"><a class="nav-link" href="/admin/users/delivery">Delivery</a></li>
                    <li class="nav-item"><a class="nav-link" href="/admin/users/comercio">Comercios</a></li>
                    <li class="nav-item"><a class="nav-link" href="/admin/config">Configuracion</a></li>
                    <li class="nav-item"><a class="nav-link" href="/admin/admins">Administradores</a></li>
                    <li class="nav-item"><a class="nav-link" href="/admin/commerce-types">Tipos</a></li>
                    {{/if}}
                    {{/if}}
                </ul>

                <div class="d-flex align-items-center gap-3 text-white">
                    {{#if user}}
                    <a href="/profile" class="btn btn-outline-light btn-sm">Mi perfil</a>
                    <span>{{user.nombre}}</span>
                    <a href="/logout" class="btn btn-danger btn-sm">Salir</a>
                    {{else}}
                    <a href="/" class="btn btn-outline-light btn-sm">Login</a>
                    <a href="/register" class="btn btn-success btn-sm">Registro</a>
                    {{/if}}
                </div>
            </div>
        </div>
    </nav>

    <main class="container py-4">
        {{{body}}}
    </main>

    <script src="/bootstrap-5.3.8-dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
