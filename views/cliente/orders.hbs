<h2 class="mb-4">Mis pedidos</h2>

{{#each orders}}
<div class="card shadow-sm border-0 mb-3">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start">
            <div>
                <h5 class="mb-1">{{this.comercio.nombre}}</h5>
                <p class="text-muted mb-1">{{this.numeroPedido}}</p>
                <p class="mb-1"><strong>Estado:</strong> {{this.estado}}</p>
                <p class="mb-1"><strong>Subtotal:</strong> RD$ {{formatCurrency this.subtotal}}</p>
                <p class="mb-1"><strong>ITBIS:</strong> RD$ {{formatCurrency this.itbis}}</p>
                <p class="mb-1"><strong>Total:</strong> RD$ {{formatCurrency this.total}}</p>
                <p class="mb-0"><strong>Entrega:</strong> {{this.direccionEntrega.alias}} - {{this.direccionEntrega.direccion}}</p>
            </div>

            {{#if (eq this.estado "pendiente")}}
            <form method="POST" action="/cliente/orders/cancel/{{this._id}}">
                <button class="btn btn-outline-danger">Cancelar</button>
            </form>
            {{/if}}
        </div>
    </div>
</div>
{{else}}
<div class="alert alert-info">Aun no has realizado pedidos.</div>
{{/each}}
