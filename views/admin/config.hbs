<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h3 class="mb-3">Configuracion</h3>

                <form method="POST" action="/admin/config">
                    <div class="mb-3">
                        <label class="form-label">ITBIS (%)</label>
                        <input type="number" min="0" step="0.01" name="itbis" class="form-control" value="{{config.itbis}}" required>
                    </div>

                    <button class="btn btn-success">Guardar configuracion</button>
                </form>
            </div>
        </div>
    </div>
</div>
