<div class="row g-4">
    <div class="col-lg-5">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h3 class="mb-3">Crear administrador</h3>

                {{#if error}}
                <div class="alert alert-danger">{{error}}</div>
                {{/if}}

                <form method="POST" action="/admin/admins">
                    <div class="mb-2"><input name="nombre" class="form-control" placeholder="Nombre" required></div>
                    <div class="mb-2"><input name="apellido" class="form-control" placeholder="Apellido" required></div>
                    <div class="mb-2"><input name="cedula" class="form-control" placeholder="Cedula" required></div>
                    <div class="mb-2"><input type="email" name="email" class="form-control" placeholder="Correo" required></div>
                    <div class="mb-2"><input name="username" class="form-control" placeholder="Usuario" required></div>
                    <div class="mb-2"><input type="password" name="password" class="form-control" placeholder="Contrasena" required></div>
                    <div class="mb-3"><input type="password" name="confirmPassword" class="form-control" placeholder="Confirmar contrasena" required></div>
                    <button class="btn btn-success">Crear administrador</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h3 class="mb-3">Administradores</h3>
                {{#each admins}}
                <div class="border rounded p-3 mb-3 d-flex justify-content-between align-items-start">
                    <div>
                        <h5 class="mb-1">{{this.nombre}} {{this.apellido}}</h5>
                        <p class="mb-1"><strong>Usuario:</strong> {{this.username}}</p>
                        <p class="mb-1"><strong>Cedula:</strong> {{this.cedula}}</p>
                        <p class="mb-0"><strong>Correo:</strong> {{this.email}}</p>
                    </div>
                    {{#if (ne this._id ../user.id)}}
                    <form method="POST" action="/admin/users/toggle/{{this._id}}">
                        <button class="btn {{#if this.activo}}btn-outline-danger{{else}}btn-success{{/if}}">
                            {{#if this.activo}}Inactivar{{else}}Activar{{/if}}
                        </button>
                    </form>
                    {{/if}}
                </div>
                {{else}}
                <div class="alert alert-info mb-0">No hay administradores registrados.</div>
                {{/each}}
            </div>
        </div>
    </div>
</div>
