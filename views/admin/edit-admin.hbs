<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="mb-0">Editar administrador</h2>
                    <a href="/admin/admins" class="btn btn-outline-secondary">Volver</a>
                </div>

                {{#if error}}
                <div class="alert alert-danger">{{error}}</div>
                {{/if}}

                <form method="POST" action="/admin/admins/{{admin._id}}">
                    <div class="mb-2"><input name="nombre" class="form-control" placeholder="Nombre" value="{{admin.nombre}}" required></div>
                    <div class="mb-2"><input name="apellido" class="form-control" placeholder="Apellido" value="{{admin.apellido}}" required></div>
                    <div class="mb-2"><input name="cedula" class="form-control" placeholder="Cedula" value="{{admin.cedula}}" required></div>
                    <div class="mb-2"><input type="email" name="email" class="form-control" placeholder="Correo" value="{{admin.email}}" required></div>
                    <div class="mb-2"><input name="username" class="form-control" placeholder="Usuario" value="{{admin.username}}" required></div>
                    <div class="mb-2"><input type="password" name="password" class="form-control" placeholder="Nueva contrasena"></div>
                    <div class="mb-3"><input type="password" name="confirmPassword" class="form-control" placeholder="Confirmar nueva contrasena"></div>
                    <div class="d-flex gap-2">
                        <a href="/admin/admins" class="btn btn-outline-secondary">Cancelar</a>
                        <button class="btn btn-success">Guardar cambios</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
