<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h3 class="mb-3">Eliminar categoria</h3>
                <p class="mb-2">Estas seguro que deseas eliminar esta categoria?</p>
                <p class="mb-1"><strong>Nombre:</strong> {{category.nombre}}</p>
                <p class="mb-3"><strong>Productos asociados:</strong> {{productsCount}}</p>

                <div class="d-flex gap-2">
                    <a href="/comercio/categories" class="btn btn-outline-secondary">Cancelar</a>
                    <form method="POST" action="/comercio/categories/delete/{{category._id}}">
                        <button class="btn btn-danger">Aceptar</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
