<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h3 class="mb-3">{{#if (eq mode "edit")}}Editar producto{{else}}Crear producto{{/if}}</h3>

                {{#if error}}
                <div class="alert alert-danger">{{error}}</div>
                {{/if}}

                <form method="POST" action="{{#if (eq mode "edit")}}/comercio/products/edit/{{values._id}}{{else}}/comercio/products{{/if}}" enctype="multipart/form-data" class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Nombre</label>
                        <input name="nombre" class="form-control" value="{{values.nombre}}" required>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Precio</label>
                        <input type="number" name="precio" class="form-control" min="0" step="0.01" value="{{values.precio}}" required>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Categoria</label>
                        <select name="categoria" class="form-select" required>
                            <option value="">Selecciona una categoria</option>
                            {{#each categories}}
                            <option value="{{this._id}}" {{#if (eq ../values.categoria this._id)}}selected{{/if}}>{{this.nombre}}</option>
                            {{/each}}
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Imagen</label>
                        <input type="file" name="imagen" class="form-control" {{#if (ne mode "edit")}}required{{/if}}>
                    </div>

                    {{#if values.imagen}}
                    <div class="col-12">
                        <img src="{{values.imagen}}" alt="{{values.nombre}}" class="img-fluid rounded border" style="max-height: 220px;">
                    </div>
                    {{/if}}

                    <div class="col-12">
                        <label class="form-label">Descripcion</label>
                        <textarea name="descripcion" class="form-control" rows="4" required>{{values.descripcion}}</textarea>
                    </div>

                    <div class="col-12 d-flex gap-2">
                        <a href="/comercio/products" class="btn btn-outline-secondary">Volver</a>
                        <button class="btn btn-success">{{#if (eq mode "edit")}}Guardar cambios{{else}}Crear producto{{/if}}</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
