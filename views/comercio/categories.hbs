<div class="row g-4">
    <div class="col-lg-4">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h3 class="mb-3">Nueva categoria</h3>

                {{#if error}}
                <div class="alert alert-danger">{{error}}</div>
                {{/if}}

                <form method="POST" action="/comercio/categories">
                    <div class="mb-3">
                        <label class="form-label">Nombre</label>
                        <input name="nombre" class="form-control" required>
                    </div>
                    <button class="btn btn-success">Guardar</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h3 class="mb-3">Categorias registradas</h3>
                {{#each categories}}
                <div class="d-flex justify-content-between align-items-center border rounded p-3 mb-3">
                    <strong>{{this.nombre}}</strong>
                    <form method="POST" action="/comercio/categories/delete/{{this._id}}">
                        <button class="btn btn-sm btn-outline-danger">Eliminar</button>
                    </form>
                </div>
                {{else}}
                <div class="alert alert-info mb-0">Aun no tienes categorias.</div>
                {{/each}}
            </div>
        </div>
    </div>
</div>
