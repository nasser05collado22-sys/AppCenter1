<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Productos</h2>
    <a href="/comercio/createProducts" class="btn btn-success">Nuevo producto</a>
</div>

<div class="row g-4">
    {{#each products}}
    <div class="col-md-6 col-xl-4">
        <div class="card h-100 shadow-sm border-0">
            {{#if this.imagen}}
            <img src="{{this.imagen}}" class="card-img-top" alt="{{this.nombre}}" style="height: 220px; object-fit: cover;">
            {{/if}}
            <div class="card-body">
                <h5>{{this.nombre}}</h5>
                <p class="text-muted">{{this.descripcion}}</p>
                <p class="mb-1"><strong>Precio:</strong> RD$ {{formatCurrency this.precio}}</p>
                <p class="mb-3"><strong>Categoria:</strong> {{this.categoria.nombre}}</p>
                <form method="POST" action="/comercio/products/delete/{{this._id}}">
                    <button class="btn btn-outline-danger">Eliminar</button>
                </form>
            </div>
        </div>
    </div>
    {{else}}
    <div class="col-12">
        <div class="alert alert-info">Todavia no has creado productos.</div>
    </div>
    {{/each}}
</div>
