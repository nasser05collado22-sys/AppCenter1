<h2 class="mb-4">Pedidos del comercio</h2>

{{#each orders}}
<div class="card shadow-sm border-0 mb-3">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start">
            <div>
                <h5 class="mb-1">{{this.numeroPedido}}</h5>
                <p class="mb-1"><strong>Cliente:</strong> {{this.cliente.nombre}} {{this.cliente.apellido}}</p>
                <p class="mb-1"><strong>Estado:</strong> {{this.estado}}</p>
                <p class="mb-1"><strong>Total:</strong> RD$ {{formatCurrency this.total}}</p>
                <p class="mb-0"><strong>Direccion:</strong> {{this.direccionEntrega.direccion}}</p>
            </div>

            {{#if (eq this.estado "pendiente")}}
            <form method="POST" action="/comercio/orders/{{this._id}}">
                <button class="btn btn-outline-warning">Pasar a preparando</button>
            </form>
            {{/if}}

            {{#if (eq this.estado "preparando")}}
            <form method="POST" action="/comercio/orders/{{this._id}}">
                <button class="btn btn-success">Marcar como listo</button>
            </form>
            {{/if}}
        </div>
    </div>
</div>
{{else}}
<div class="alert alert-info">No hay pedidos registrados.</div>
{{/each}}
