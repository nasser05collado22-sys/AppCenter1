<h2 class="mb-4">Mis pedidos</h2>

{{#each orders}}
<div class="card shadow-sm border-0 mb-3">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start">
            <div>
                <h5 class="mb-1">{{this.comercio.nombre}}</h5>
                <p class="mb-1"><strong>Pedido:</strong> {{this.numeroPedido}}</p>
                <p class="mb-1"><strong>Estado:</strong> {{this.estado}}</p>
                <p class="mb-1"><strong>Total:</strong> RD$ {{formatCurrency this.total}}</p>
                {{#if (ne this.estado "entregado")}}
                <p class="mb-0"><strong>Direccion:</strong> {{this.direccionEntrega.direccion}}</p>
                {{/if}}
            </div>

            <div class="d-flex gap-2">
                {{#if (eq this.estado "en camino")}}
                <form method="POST" action="/delivery/orders/complete/{{this._id}}">
                    <button class="btn btn-success">Completar</button>
                </form>
                <form method="POST" action="/delivery/orders/leave/{{this._id}}">
                    <button class="btn btn-outline-danger">Soltar</button>
                </form>
                {{/if}}
            </div>
        </div>
    </div>
</div>
{{else}}
<div class="alert alert-info">Aun no tienes pedidos asignados.</div>
{{/each}}
