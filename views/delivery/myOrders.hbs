<h2 class="mb-4">Mis pedidos</h2>

{{#each orders}}
<div class="card shadow-sm border-0 mb-3">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start">
            <div>
                <h5 class="mb-1">{{this.comercio.nombre}}</h5>
                <p class="mb-1"><strong>Pedido:</strong> {{this.numeroPedido}}</p>
                <p class="mb-1"><strong>Estado:</strong> {{this.estado}}</p>
                <p class="mb-1"><strong>Total:</strong> RD$ {{formatCurrency this.total}}</p>
                <p class="mb-1"><strong>Productos:</strong> {{this.productosCount}}</p>
                {{#if (ne this.estado "completado")}}
                <p class="mb-0"><strong>Direccion:</strong> {{this.direccionEntrega.direccion}}</p>
                {{/if}}
            </div>

            <div class="d-flex gap-2">
                <a href="/delivery/orders/{{this._id}}" class="btn btn-outline-primary">Ver detalle</a>
            </div>
        </div>
    </div>
</div>
{{else}}
<div class="alert alert-info">Aun no tienes pedidos asignados.</div>
{{/each}}
