<h2 class="mb-4">Pedidos disponibles</h2>

{{#each orders}}
<div class="card shadow-sm border-0 mb-3">
    <div class="card-body d-flex justify-content-between align-items-start">
        <div>
            <h5 class="mb-1">{{this.comercio.nombre}}</h5>
            <p class="mb-1"><strong>Pedido:</strong> {{this.numeroPedido}}</p>
            <p class="mb-1"><strong>Cliente:</strong> {{this.cliente.nombre}}</p>
            <p class="mb-1"><strong>Estado actual:</strong> {{this.estado}}</p>
            <p class="mb-1"><strong>Total:</strong> RD$ {{formatCurrency this.total}}</p>
            <p class="mb-0"><strong>Productos:</strong> {{this.productosCount}}</p>
        </div>

        <form method="POST" action="/delivery/orders/accept/{{this._id}}">
            <button class="btn btn-success">Aceptar</button>
        </form>
    </div>
</div>
{{else}}
<div class="alert alert-info">No hay pedidos disponibles para tomar.</div>
{{/each}}
