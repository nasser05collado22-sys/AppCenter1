<div class="row justify-content-center">
    <div class="col-xl-8">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h3 class="mb-3">Registro</h3>

                {{#if error}}
                <div class="alert alert-danger">{{error}}</div>
                {{/if}}

                <form method="POST" action="/register" enctype="multipart/form-data" class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label" id="nombreLabel">Nombre</label>
                        <input name="nombre" class="form-control" value="{{values.nombre}}" required>
                    </div>

                    <div class="col-md-6" id="apellidoGroup">
                        <label class="form-label">Apellido</label>
                        <input name="apellido" class="form-control" value="{{values.apellido}}">
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Telefono</label>
                        <input name="telefono" class="form-control" value="{{values.telefono}}" required>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Correo</label>
                        <input type="email" name="email" class="form-control" value="{{values.email}}" required>
                    </div>

                    <div class="col-md-6" id="usernameGroup">
                        <label class="form-label">Usuario</label>
                        <input name="username" class="form-control" value="{{values.username}}" required>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Foto o logo</label>
                        <input type="file" name="foto" class="form-control">
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Rol</label>
                        <select name="role" class="form-select">
                            <option value="cliente" {{#if (eq values.role "cliente")}}selected{{/if}}>Cliente</option>
                            <option value="delivery" {{#if (eq values.role "delivery")}}selected{{/if}}>Delivery</option>
                            <option value="comercio" {{#if (eq values.role "comercio")}}selected{{/if}}>Comercio</option>
                        </select>
                    </div>

                    <div class="col-md-6" id="tipoComercioGroup">
                        <label class="form-label">Tipo de comercio</label>
                        <select name="tipoComercio" class="form-select">
                            <option value="">Selecciona uno</option>
                            {{#each tiposComercio}}
                            <option value="{{this._id}}" {{#if (eq ../values.tipoComercio this._id)}}selected{{/if}}>{{this.nombre}}</option>
                            {{/each}}
                        </select>
                    </div>

                    <div class="col-md-6" id="aperturaGroup">
                        <label class="form-label">Hora de apertura</label>
                        <input type="time" name="horarioApertura" class="form-control" value="{{values.horarioApertura}}">
                    </div>

                    <div class="col-md-6" id="cierreGroup">
                        <label class="form-label">Hora de cierre</label>
                        <input type="time" name="horarioCierre" class="form-control" value="{{values.horarioCierre}}">
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Contrasena</label>
                        <input type="password" name="password" class="form-control" required>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Confirmar contrasena</label>
                        <input type="password" name="confirmPassword" class="form-control" required>
                    </div>

                    <div class="col-12 d-flex gap-2">
                        <a href="/" class="btn btn-outline-secondary">Volver</a>
                        <button class="btn btn-success">Crear cuenta</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    (() => {
        const roleSelect = document.querySelector('select[name="role"]');
        const nombreLabel = document.getElementById("nombreLabel");
        const apellidoGroup = document.getElementById("apellidoGroup");
        const usernameGroup = document.getElementById("usernameGroup");
        const tipoComercioGroup = document.getElementById("tipoComercioGroup");
        const aperturaGroup = document.getElementById("aperturaGroup");
        const cierreGroup = document.getElementById("cierreGroup");
        const apellidoInput = document.querySelector('input[name="apellido"]');
        const usernameInput = document.querySelector('input[name="username"]');
        const tipoComercioInput = document.querySelector('select[name="tipoComercio"]');
        const aperturaInput = document.querySelector('input[name="horarioApertura"]');
        const cierreInput = document.querySelector('input[name="horarioCierre"]');

        const syncRoleFields = () => {
            const isCommerce = roleSelect.value === "comercio";

            nombreLabel.textContent = isCommerce ? "Nombre del comercio" : "Nombre";
            apellidoGroup.style.display = isCommerce ? "none" : "";
            usernameGroup.style.display = isCommerce ? "none" : "";
            tipoComercioGroup.style.display = isCommerce ? "" : "none";
            aperturaGroup.style.display = isCommerce ? "" : "none";
            cierreGroup.style.display = isCommerce ? "" : "none";

            apellidoInput.required = !isCommerce;
            usernameInput.required = !isCommerce;
            tipoComercioInput.required = isCommerce;
            aperturaInput.required = isCommerce;
            cierreInput.required = isCommerce;
        };

        roleSelect.addEventListener("change", syncRoleFields);
        syncRoleFields();
    })();
</script>
